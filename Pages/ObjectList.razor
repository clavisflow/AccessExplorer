@using System.Globalization
<article class="object-list">
    <div>
        <h3>@Title</h3>
        <span>@Items.Count.ToString("N0")</span>
    </div>
    @if (Items.Count == 0)
    {
        <p class="muted">検出なし</p>
    }
    else
    {
        <ul>
            @foreach (var item in Items)
            {
                var objectMeta = ObjectMeta(item);

                <li>
                    <strong>@item.Name</strong>
                    @if (!string.IsNullOrWhiteSpace(objectMeta))
                    {
                        <small>@objectMeta</small>
                    }
                </li>
            }
        </ul>
    }
</article>

@code {
    [Parameter]
    public string Title { get; set; } = string.Empty;

    [Parameter]
    public IReadOnlyList<AccessObjectDetail> Items { get; set; } = [];

    private static string ObjectMeta(AccessObjectDetail item)
    {
        var values = new List<string>();

        var updatedLabel = BuildObjectDateLabel("更新", item.DateUpdate);
        if (!string.IsNullOrWhiteSpace(updatedLabel))
        {
            values.Add(updatedLabel);
        }

        var createdLabel = BuildObjectDateLabel("作成", item.DateCreate);
        if (!string.IsNullOrWhiteSpace(createdLabel))
        {
            values.Add(createdLabel);
        }

        return string.Join(" / ", values);
    }

    private static string? BuildObjectDateLabel(string label, string? value)
    {
        var formatted = FormatObjectDate(value);
        return string.IsNullOrWhiteSpace(formatted)
            ? null
            : $"{label} {formatted}";
    }

    private static string? FormatObjectDate(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return null;
        }

        string[] formats =
        {
            "M/d/yy H:mm:ss",
            "MM/dd/yy HH:mm:ss"
        };

        return DateTimeOffset.TryParseExact(
            value,
            formats,
            CultureInfo.InvariantCulture,
            DateTimeStyles.None,
            out var parsed)
                ? parsed.ToString("yy/MM/dd HH:mm", CultureInfo.InvariantCulture)
                : value;
    }
}
